<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register New Role</title>
  </head>
  <body>
    <h1>SIGN UP NEW ROLE</h1>
    <form action="/registerrole" method="POST">
      <div>
        <label for="firstname">Enter First Name:</label>
        <input
          type="text"
          name="firstname"
          id="firstname"
          placeholder="firstname"
        />
      </div>
      <div>
        <label for="lastname">Enter Last Name:</label>
        <input
          type="text"
          name="lastname"
          id="lastname"
          placeholder="lastname"
        />
      </div>
      <div>
        <label for="email">Enter Email Address:</label>
        <input type="text" name="email" id="email" placeholder="email" />
      </div>
      <div>
        <label for="affiliation">Enter Affiliation:</label>
        <input
          type="text"
          name="affiliation"
          id="affiliation"
          placeholder="affiliation"
        />
      </div>
      <div>
        <label for="credentials">Enter Credentials:</label>
        <input
          type="text"
          name="credentials"
          id="credentials"
          placeholder="credentials"
        />
      </div>
      <div>
        <label for="password">Enter Password:</label>
        <input
          type="text"
          name="password"
          id="password"
          placeholder="password"
        />
      </div>
      <!-- ONLY VISIBLE IF ADMIN IS -->
      <div>
        <label for="role">Enter Role:</label>
        <input type="text" name="role" id="role" placeholder="role" />
      </div>
      <button>Sign Up</button>
      <button>Cancel</button>
    </form>
  </body>
</html>
